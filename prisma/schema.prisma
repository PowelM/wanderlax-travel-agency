generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String           @id @default(uuid())
  clerkId                String           @unique
  email                  String           @unique
  firstName              String?
  lastName               String?
  phone                  String?
  avatarUrl              String?
  role                   Role             @default(CUSTOMER)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  loyaltyPoints          Int              @default(0)
  activityLogs           ActivityLog[]
  appointmentsClient     Appointment[]    @relation("ClientAppointments")
  appointmentsConsultant Appointment[]    @relation("ConsultantAppointments")
  bookings               Booking[]
  carHireBookings        CarHireBooking[]
  hotelBookings          HotelBooking[]
  inquiries              Inquiry[]
  inquiryMessages        InquiryMessage[]
  notifications          Notification[]
  payments               Payment[]
  reviews                Review[]
  sessions               Session[]
  staffProfile           StaffProfile?
  tourBookings           TourBooking[]
  wishlistItems          WishlistItem[]
  EventBooking           EventBooking[]

  @@index([email])
  @@index([role])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model StaffProfile {
  id           String            @id @default(uuid())
  userId       String            @unique
  department   String?
  jobTitle     String?
  bio          String?
  hireDate     DateTime?
  isActive     Boolean           @default(true)
  blockedDates BlockedDate[]
  permissions  StaffPermission[]
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StaffPermission {
  id             String       @id @default(uuid())
  staffProfileId String
  module         String
  canView        Boolean      @default(false)
  canCreate      Boolean      @default(false)
  canEdit        Boolean      @default(false)
  canDelete      Boolean      @default(false)
  canExport      Boolean      @default(false)
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, module])
}

model BlockedDate {
  id             String       @id @default(uuid())
  staffProfileId String
  startDate      DateTime
  endDate        DateTime
  reason         String?
  createdAt      DateTime     @default(now())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
}

model Destination {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  country      String
  continent    String
  description  String?
  images       String[]
  featured     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  hotels       Hotel[]
  tourPackages TourPackage[]

  @@index([slug])
  @@index([country])
  @@index([continent])
}

model Car {
  id              String           @id @default(uuid())
  make            String
  model           String
  year            Int
  licensePlate    String           @unique
  category        CarCategory
  capacity        Int
  transmission    String
  fuelType        String
  dailyRate       Decimal          @db.Decimal(10, 2)
  images          String[]
  status          CarStatus        @default(AVAILABLE)
  mileage         Int?
  features        String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bookings        CarHireBooking[]
  maintenanceLogs MaintenanceLog[]

  @@index([status])
  @@index([category])
}

model CarHireBooking {
  id              String        @id @default(uuid())
  userId          String
  carId           String
  pickupLocation  String
  dropoffLocation String
  pickupDateTime  DateTime
  returnDateTime  DateTime
  totalDays       Int
  dailyRate       Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          BookingStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  booking         Booking?      @relation("CarBooking")
  car             Car           @relation(fields: [carId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([carId])
  @@index([status])
  @@index([pickupDateTime])
}

model MaintenanceLog {
  id          String          @id @default(uuid())
  carId       String
  type        MaintenanceType
  description String
  cost        Decimal?        @db.Decimal(10, 2)
  date        DateTime
  provider    String?
  invoiceUrl  String?
  createdAt   DateTime        @default(now())
  car         Car             @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model Hotel {
  id            String          @id @default(uuid())
  destinationId String
  name          String
  slug          String          @unique
  description   String
  starRating    HotelStarRating @default(UNRATED)
  address       String
  latitude      Float?
  longitude     Float?
  amenities     String[]
  images        String[]
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  destination   Destination     @relation(fields: [destinationId], references: [id])
  bookings      HotelBooking[]
  rooms         HotelRoom[]
  reviews       Review[]

  @@index([slug])
  @@index([destinationId])
  @@index([starRating])
}

model HotelRoom {
  id             String         @id @default(uuid())
  hotelId        String
  type           RoomType
  name           String
  description    String?
  capacityAdults Int
  capacityKids   Int            @default(0)
  pricePerNight  Decimal        @db.Decimal(10, 2)
  quantity       Int            @default(1)
  images         String[]
  amenities      String[]
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  bookings       HotelBooking[]
  hotel          Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model HotelBooking {
  id              String        @id @default(uuid())
  userId          String
  hotelId         String
  roomId          String?
  checkIn         DateTime
  checkOut        DateTime
  guestsAdults    Int
  guestsKids      Int           @default(0)
  totalNights     Int
  pricePerNight   Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          BookingStatus @default(PENDING)
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  booking         Booking?      @relation("HotelBooking")
  hotel           Hotel         @relation(fields: [hotelId], references: [id])
  room            HotelRoom?    @relation(fields: [roomId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([hotelId])
  @@index([status])
  @@index([checkIn])
}

model TourPackage {
  id             String             @id @default(uuid())
  destinationId  String
  title          String
  slug           String             @unique
  category       TourCategory
  overview       String
  durationDays   Int
  durationNights Int
  basePrice      Decimal            @db.Decimal(10, 2)
  groupSizeMin   Int                @default(1)
  groupSizeMax   Int
  included       String[]
  excluded       String[]
  images         String[]
  featured       Boolean            @default(false)
  status         String             @default("ACTIVE")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  reviews        Review[]
  availabilities TourAvailability[]
  bookings       TourBooking[]
  itinerary      TourItinerary[]
  destination    Destination        @relation(fields: [destinationId], references: [id])

  @@index([slug])
  @@index([destinationId])
  @@index([category])
  @@index([status])
}

model TourItinerary {
  id            String      @id @default(uuid())
  tourPackageId String
  dayNumber     Int
  title         String
  description   String
  accommodation String?
  mealsIncluded String[]
  activities    String[]
  tourPackage   TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)

  @@unique([tourPackageId, dayNumber])
}

model TourAvailability {
  id            String      @id @default(uuid())
  tourPackageId String
  startDate     DateTime
  endDate       DateTime
  priceOverride Decimal?    @db.Decimal(10, 2)
  capacity      Int
  bookedCount   Int         @default(0)
  status        String      @default("AVAILABLE")
  createdAt     DateTime    @default(now())
  tourPackage   TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
}

model TourBooking {
  id                  String         @id @default(uuid())
  userId              String
  tourPackageId       String
  startDate           DateTime
  endDate             DateTime
  guestCount          Int
  totalAmount         Decimal        @db.Decimal(10, 2)
  status              BookingStatus  @default(PENDING)
  specialRequirements String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  booking             Booking?       @relation("TourBooking")
  tourPackage         TourPackage    @relation(fields: [tourPackageId], references: [id])
  user                User           @relation(fields: [userId], references: [id])
  travelers           TourTraveler[]

  @@index([userId])
  @@index([tourPackageId])
  @@index([status])
}

model TourTraveler {
  id             String      @id @default(uuid())
  tourBookingId  String
  firstName      String
  lastName       String
  passportNumber String?
  dateOfBirth    DateTime?
  dietaryReqs    String?
  isLeadGuest    Boolean     @default(false)
  tourBooking    TourBooking @relation(fields: [tourBookingId], references: [id], onDelete: Cascade)
}

model Booking {
  id               String          @id @default(uuid())
  bookingRef       String          @unique
  userId           String
  serviceType      ServiceType
  status           BookingStatus   @default(PENDING)
  paymentStatus    PaymentStatus   @default(PENDING)
  totalAmount      Decimal         @db.Decimal(10, 2)
  discountAmount   Decimal         @default(0) @db.Decimal(10, 2)
  taxAmount        Decimal         @default(0) @db.Decimal(10, 2)
  finalAmount      Decimal         @db.Decimal(10, 2)
  currency         String          @default("USD")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  carHireBookingId String?         @unique
  hotelBookingId   String?         @unique
  tourBookingId    String?         @unique
  appointmentId    String?         @unique
  eventBookingId   String?         @unique
  appointment      Appointment?    @relation("AppointmentBooking", fields: [appointmentId], references: [id])
  carHireBooking   CarHireBooking? @relation("CarBooking", fields: [carHireBookingId], references: [id])
  hotelBooking     HotelBooking?   @relation("HotelBooking", fields: [hotelBookingId], references: [id])
  tourBooking      TourBooking?    @relation("TourBooking", fields: [tourBookingId], references: [id])
  eventBooking     EventBooking?   @relation("EventBooking", fields: [eventBookingId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
  invoice          Invoice?
  payments         Payment[]

  @@index([userId])
  @@index([serviceType])
  @@index([status])
  @@index([paymentStatus])
}

model Payment {
  id               String        @id @default(uuid())
  bookingId        String
  userId           String
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  transactionId    String?       @unique
  providerResponse Json?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  booking          Booking       @relation(fields: [bookingId], references: [id])
  user             User          @relation(fields: [userId], references: [id])

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([method])
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  bookingId     String   @unique
  issueDate     DateTime @default(now())
  dueDate       DateTime
  subtotal      Decimal  @db.Decimal(10, 2)
  tax           Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  pdfUrl        String?
  status        String   @default("UNPAID")
  createdAt     DateTime @default(now())
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Appointment {
  id              String            @id @default(uuid())
  clientId        String
  consultantId    String
  topic           String
  scheduledAt     DateTime
  durationMinutes Int               @default(60)
  meetingUrl      String?
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  client          User              @relation("ClientAppointments", fields: [clientId], references: [id])
  consultant      User              @relation("ConsultantAppointments", fields: [consultantId], references: [id])
  booking         Booking?          @relation("AppointmentBooking")

  @@index([clientId])
  @@index([consultantId])
  @@index([status])
  @@index([scheduledAt])
}

model Review {
  id            String       @id @default(uuid())
  userId        String
  rating        Int          @db.SmallInt
  title         String?
  comment       String
  isPublished   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  hotelId       String?
  tourPackageId String?
  hotel         Hotel?       @relation(fields: [hotelId], references: [id])
  tourPackage   TourPackage? @relation(fields: [tourPackageId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
}

model Inquiry {
  id         String           @id @default(uuid())
  userId     String?
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  status     InquiryStatus    @default(NEW)
  assignedTo String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User?            @relation(fields: [userId], references: [id])
  messages   InquiryMessage[]
}

model InquiryMessage {
  id           String   @id @default(uuid())
  inquiryId    String
  senderId     String?
  message      String
  isStaffReply Boolean  @default(false)
  createdAt    DateTime @default(now())
  inquiry      Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  sender       User?    @relation(fields: [senderId], references: [id])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  itemType  String
  itemId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Promotion {
  id            String   @id @default(uuid())
  code          String   @unique
  description   String?
  discountType  String
  discountValue Decimal  @db.Decimal(10, 2)
  minSpend      Decimal? @db.Decimal(10, 2)
  validFrom     DateTime
  validUntil    DateTime
  maxUses       Int?
  currentUses   Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model NewsletterSubscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  firstName      String?
  source         String?
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  subject     String
  htmlContent String
  textContent String
  variables   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  module    String
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([createdAt])
}

model SiteSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
}

enum Role {
  CUSTOMER
  CONSULTANT
  ADMIN
  SUPER_ADMIN
}

model Event {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  description String
  category    EventCategory  @default(GENERAL)
  status      EventStatus    @default(UPCOMING)
  startDate   DateTime
  endDate     DateTime
  location    String
  price       Decimal        @db.Decimal(10, 2)
  capacity    Int
  soldTickets Int            @default(0)
  images      String[]
  featured    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  bookings    EventBooking[]

  @@index([slug])
  @@index([status])
  @@index([startDate])
  @@index([category])
}

model EventBooking {
  id          String        @id @default(uuid())
  userId      String
  eventId     String
  ticketCount Int
  totalAmount Decimal       @db.Decimal(10, 2)
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking?      @relation("EventBooking")
  event       Event         @relation(fields: [eventId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  tickets     Ticket[]

  @@index([userId])
  @@index([eventId])
  @@index([status])
}

model Ticket {
  id             String       @id @default(uuid())
  eventBookingId String
  ticketNumber   String       @unique
  attendeeName   String?
  attendeeEmail  String?
  status         TicketStatus @default(VALID)
  qrCodeUrl      String?
  scannedAt      DateTime?
  eventBooking   EventBooking @relation(fields: [eventBookingId], references: [id], onDelete: Cascade)

  @@index([ticketNumber])
  @@index([status])
  @@index([eventBookingId])
}

// Enums removed: ModuleType, PermissionLevel

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  PAYPAL
  BANK_TRANSFER
  STRIPE
}

enum ServiceType {
  CAR_HIRE
  HOTEL
  TOUR_PACKAGE
  FLIGHT
  CUSTOM
  EVENT
}

enum CarStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  DECOMMISSIONED
}

enum CarCategory {
  ECONOMY
  COMPACT
  SUV
  LUXURY
  VAN
  BUS
}

enum MaintenanceType {
  ROUTINE
  REPAIR
  INSPECTION
  CLEANING
}

enum HotelStarRating {
  ONE_STAR
  TWO_STAR
  THREE_STAR
  FOUR_STAR
  FIVE_STAR
  UNRATED
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  FAMILY
  PENTHOUSE
}

enum TourCategory {
  SAFARI
  BEACH
  CULTURAL
  ADVENTURE
  HONEYMOON
  FAMILY
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventCategory {
  CONCERT
  WORKSHOP
  FESTIVAL
  CONFERENCE
  EXHIBITION
  GENERAL
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
}
